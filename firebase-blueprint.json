{
  "entities": {
    "Flashcard": {
      "title": "Flashcard",
      "description": "A single information flashcard",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "meaning": { "type": "string" },
        "meaningTr": { "type": "string" },
        "hint": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "number", "format": "timestamp" }
      },
      "required": ["word", "meaning", "meaningTr", "hint", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/flashcards/{flashcardId}": {
      "schema": "Flashcard",
      "description": "A user's collection of flashcards"
    }
  }
}
