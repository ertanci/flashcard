rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Flashcard validation
    function isValidFlashcard(data) {
      return data.word is string && data.word.size() > 0 && data.word.size() <= 500 &&
             data.meaning is string && data.meaning.size() > 0 && data.meaning.size() <= 2000 &&
             data.meaningTr is string && data.meaningTr.size() > 0 && data.meaningTr.size() <= 2000 &&
             data.hint is string && data.hint.size() <= 1000 &&
             data.userId == request.auth.uid &&
             data.createdAt is number;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);

      match /flashcards/{flashcardId} {
        allow read: if isOwner(userId);
        
        allow create: if isOwner(userId) && 
                         isValidId(flashcardId) && 
                         isValidFlashcard(request.resource.data);
                         
        allow update: if isOwner(userId) && 
                         isValidFlashcard(request.resource.data) &&
                         request.resource.data.userId == resource.data.userId &&
                         request.resource.data.createdAt == resource.data.createdAt;
                         
        allow delete: if isOwner(userId);
      }
    }
  }
}
